# =============================================================================
# Lambda Labs Orchestrator - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# The .env file is in .dockerignore and will NOT be included in Docker images

# =============================================================================
# GCP Configuration (for deployment)
# =============================================================================
GCP_PROJECT=your-gcp-project
GCP_REGION=us-central1
DOCKERHUB_USER=your-dockerhub-username

# =============================================================================
# Lambda Labs API
# =============================================================================
# Get your API key from: https://cloud.lambda.ai/api-keys
LAMBDA_API_KEY=your-lambda-api-key

# SSH key name in Lambda Labs (will be created if it doesn't exist)
LAMBDA_SSH_KEY_NAME=orchestrator-key

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# Discord Integration (optional)
# =============================================================================
# Webhook URL for sending approval requests
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Approval timeout in seconds (default: 300 = 5 minutes)
DISCORD_APPROVAL_TIMEOUT=300

# Whether Discord approval is required (true/false)
DISCORD_REQUIRE_APPROVAL=true

# Callback URL for Discord approval buttons (set to Cloud Run URL in production)
DISCORD_CALLBACK_URL=http://localhost:8080

# Secret token for Discord callback URLs (bypasses GCP auth for approve/reject links)
# If not set, will be auto-generated during deployment
# DISCORD_CALLBACK_SECRET=your-secret-here

# =============================================================================
# API Authentication
# =============================================================================
# API secret key for application-level authentication (alternative to GCP tokens)
# If not set, will be auto-generated during deployment
# Can be used with X-API-Key header for programmatic access
# API_SECRET_KEY=your-api-key-here

# =============================================================================
# Orchestrator Settings
# =============================================================================
# Dry run mode - don't actually launch/terminate instances
DRY_RUN=false

# API server port
API_PORT=8080

# =============================================================================
# GCS Configuration (for training data and outputs)
# =============================================================================
OUTPUT_GCS_PATH=gs://your-bucket/training-outputs

# GCS Service Account Key (base64 encoded) - used by Lambda instances to access GCS
# OPTION 1 (recommended): Place your service account JSON file at:
#   sfcompute_orchestrator/gcs-key-auth.json
# The deploy script will automatically read and encode it.
#
# OPTION 2: Set this manually with: cat your-service-account.json | base64 -w0
# GCS_SERVICE_ACCOUNT_KEY_B64=

# =============================================================================
# GitHub Access (for private repos)
# =============================================================================
# GitHub Personal Access Token for cloning private repos on Lambda instances
# Generate at: https://github.com/settings/tokens (needs 'repo' scope)
GITHUB_TOKEN=
